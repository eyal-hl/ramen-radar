---
import { seedPlaces } from '../../data/seed';
import { joinBase } from '../../domain/urls';

export function getStaticPaths() {
  return seedPlaces.map(({ id }) => ({ params: { id } }));
}

const id = Astro.params.id ?? '';
const destination = `${joinBase(import.meta.env.BASE_URL, 'place/')}?id=${encodeURIComponent(id)}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <link rel="canonical" href={destination} />
    <title>Place moved · Ramen Radar</title>
  </head>
  <body>
    <p>This place moved to <a href={destination}>{destination}</a>.</p>
    <script is:inline define:vars={{ destination }}>location.replace(destination);</script>
  </body>
</html>
