---
import '../styles/global.css';
import { joinBase } from '../domain/urls';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ramen Radar',
  description = 'A personal field guide to ramen around Givatayim and Tel Aviv.',
} = Astro.props;
const homeUrl = joinBase(import.meta.env.BASE_URL, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#172522" />
    <link rel="icon" href={`data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🍜</text></svg>`} />
    <title>{title === 'Ramen Radar' ? title : `${title} · Ramen Radar`}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={homeUrl} aria-label="Ramen Radar home">
        <span class="brand-mark" aria-hidden="true">RR</span>
        <span>Ramen Radar</span>
      </a>
      <span class="site-kicker">Givatayim → Tel Aviv</span>
    </header>
    <slot />
    <footer class="site-footer">
      <p>Built bowl by bowl. Ratings are personal opinions, not universal noodle law.</p>
    </footer>
  </body>
</html>
