---
import { Image } from 'astro:assets';
import type { Place } from '../domain/place-schema';
interface Props { images: Place['gallery']; title?: string }
const { images, title = 'Gallery' } = Astro.props;
---
{images.length > 0 && (
  <section class="detail-section">
    <div class="section-heading"><p class="eyebrow">On the table</p><h2>{title}</h2></div>
    <div class="image-gallery">
      {images.map((image) => <figure><Image src={image.src} alt={image.alt} width={900} height={600} /><figcaption>{image.caption}</figcaption></figure>)}
    </div>
  </section>
)}

