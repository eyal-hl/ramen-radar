---
import type { Visit } from '../domain/place-schema';
import ReviewRatings from './ReviewRatings.astro';
interface Props { visit: Visit; number: number }
const { visit, number } = Astro.props;
const date = new Intl.DateTimeFormat('en-IL', { dateStyle: 'long' }).format(new Date(`${visit.date}T12:00:00`));
---
<article class="visit-card">
  <header class="visit-card__header"><div><p class="eyebrow">Visit {number}</p><h3>{date}</h3></div><span>{visit.reviews.length} {visit.reviews.length === 1 ? 'reviewer' : 'reviewers'}</span></header>
  {visit.notes && <p class="visit-note">{visit.notes}</p>}
  {visit.dishes.length > 0 && <div class="dish-list"><h4>Ordered</h4><ul>{visit.dishes.map((dish) => <li><strong>{dish.name}</strong>{dish.notes && <span>{dish.notes}</span>}</li>)}</ul></div>}
  <div class="review-grid">{visit.reviews.map((review) => <ReviewRatings review={review} />)}</div>
</article>

