---
import type { MapPlace } from '../domain/map';
interface Props { places: MapPlace[] }
const { places } = Astro.props;
const serializedPlaces = JSON.stringify(places).replaceAll('<', '\\u003c');
---
<section class="directory-map-panel" data-map-panel hidden>
  <div class="map-legend" aria-label="Map marker legend">
    <span><i class="map-marker--visited"></i>Visited</span>
    <span><i class="map-marker--want-to-visit"></i>Want to visit</span>
    <span><i class="map-marker--unavailable"></i>Unavailable</span>
  </div>
  <p class="map-instructions" id="map-instructions">Use the map controls to zoom and pan. Select a marker for place details.</p>
  <div class="directory-map" data-directory-map role="region" aria-label="Ramen places map" aria-describedby="map-instructions"></div>
  <p class="map-status" data-map-status role="status" aria-live="polite"></p>
  <script is:inline type="application/json" data-map-data set:html={serializedPlaces} />
</section>
