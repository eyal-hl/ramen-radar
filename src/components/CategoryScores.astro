---
import { RATING_CATEGORIES, formatScore } from '../domain/ratings';
import type { RatingKey } from '../domain/place-schema';
interface Props { categories: Record<RatingKey, number | null> }
const { categories } = Astro.props;
---
<div class="category-scores">
  {RATING_CATEGORIES.map(({ key, label }) => (
    <div class="category-score">
      <div><span>{label}</span><strong>{formatScore(categories[key])}</strong></div>
      <div class="score-track" aria-hidden="true"><span style={`--score: ${categories[key] ?? 0}`}></span></div>
    </div>
  ))}
</div>

