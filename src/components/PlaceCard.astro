---
import { Image } from 'astro:assets';
import type { PlaceCard as Card } from '../domain/places';
import { joinBase } from '../domain/urls';
import ScoreBadge from './ScoreBadge.astro';
import StatusChip from './StatusChip.astro';

interface Props { place: Card }
const { place } = Astro.props;
const detailUrl = joinBase(import.meta.env.BASE_URL, `places/${place.id}/`);
const date = place.latestVisit
  ? new Intl.DateTimeFormat('en-IL', { dateStyle: 'medium' }).format(new Date(`${place.latestVisit}T12:00:00`))
  : null;
---

<article
  class="place-card"
  data-place-card
  data-search={place.searchText}
  data-status={place.status}
  data-city={place.location.city.toLocaleLowerCase()}
  data-styles={place.ramenStyles.map((value) => value.toLocaleLowerCase()).join('|')}
  data-diets={place.dietaryOptions.map((value) => value.toLocaleLowerCase()).join('|')}
  data-price={place.priceRange}
  data-score={place.score ?? ''}
  data-name={place.name.toLocaleLowerCase()}
  data-latest={place.latestVisit ?? ''}
  data-added={place.addedAt}
>
  <a class="place-card__image" href={detailUrl} tabindex="-1" aria-hidden="true">
    <Image src={place.coverImage.src} alt={place.coverImage.alt} width={720} height={480} />
    {place.fictional && <span class="fictional-flag">Fictional example</span>}
  </a>
  <div class="place-card__body">
    <div class="place-card__eyebrow">
      <StatusChip status={place.status} />
      <span>{place.location.city} · {place.priceRange}</span>
    </div>
    <div class="place-card__heading">
      <div>
        <h2><a href={detailUrl}>{place.name}</a></h2>
        <p>{place.description}</p>
      </div>
      <ScoreBadge score={place.score} />
    </div>
    <div class="tag-list" aria-label="Ramen styles and tags">
      {place.ramenStyles.slice(0, 3).map((style) => <span>{style}</span>)}
      {place.tags.filter((tag) => tag !== 'fictional').slice(0, 2).map((tag) => <span>{tag}</span>)}
    </div>
    <div class="place-card__footer">
      <span>{place.visitCount === 0 ? 'No visits yet' : `${place.visitCount} ${place.visitCount === 1 ? 'visit' : 'visits'}`}</span>
      {date && <span>Latest · {date}</span>}
      <span class="place-card__arrow" aria-hidden="true">↗</span>
    </div>
  </div>
</article>
