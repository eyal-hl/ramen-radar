{
  "name": "ramen-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "check": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro check",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --project ramen-radar-rules-test --only firestore \"vitest run tests/firestore.rules.test.ts\"",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/preact": "^4.1.3",
    "astro": "^5.0.0",
    "firebase": "^12.15.0",
    "leaflet": "^1.9.4",
    "preact": "^10.29.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@axe-core/playwright": "^4.10.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.50.0",
    "@types/leaflet": "^1.9.21",
    "cross-env": "^10.1.0",
    "firebase-tools": "^15.22.4",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
